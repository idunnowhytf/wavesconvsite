{
  "name": "waves-converter",
  "version": "1.4.9",
  "description": "WavesConverter – YouTube Downloader & Converter",
  "main": "main.js",
  "author": "WavesConverter",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "publish": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.wavesconverter.app",
    "productName": "WavesConverter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "renderer.js",
      "assets/**"
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "idunnowhytf",
      "repo": "WavesConverter",
      "releaseType": "release"
    }
  },
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "electron-updater": "^6.8.3",
    "fluent-ffmpeg": "^2.1.3",
    "qrcode": "^1.5.4",
    "yt-dlp-wrap": "^2.3.12"
  }
}
