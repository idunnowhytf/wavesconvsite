{
  "name": "wavesconv",
  "version": "1.6.0",
  "description": "CLI: pobieranie YouTube (yt-dlp) i konwersja mediów (ffmpeg) — WavesConverter",
  "main": "cli.js",
  "bin": {
    "wavesconv": "./cli.js"
  },
  "files": [
    "cli.js",
    "lib",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idunnowhytf/wavesconvsite.git"
  },
  "homepage": "https://github.com/idunnowhytf/wavesconvsite#readme",
  "bugs": {
    "url": "https://github.com/idunnowhytf/wavesconvsite/issues"
  },
  "keywords": [
    "youtube",
    "yt-dlp",
    "ffmpeg",
    "downloader",
    "converter",
    "cli",
    "wavesconverter"
  ],
  "author": "WavesConverter",
  "scripts": {
    "start": "electron .",
    "cli": "node cli.js",
    "prepublishOnly": "node cli.js --version",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "publish:app": "electron-builder --publish always",
    "publish:npm": "npm publish --access public"
  },
  "build": {
    "appId": "com.wavesconverter.app",
    "productName": "WavesConverter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "cli.js",
      "lib/**",
      "preload.js",
      "index.html",
      "style.css",
      "renderer.js",
      "assets/**"
    ],
    "protocols": [
      {
        "name": "WavesConverter",
        "schemes": ["wavesconverter"]
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "idunnowhytf",
      "repo": "WavesConverter",
      "releaseType": "release"
    }
  },
  "license": "ISC",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.4"
  }
}
